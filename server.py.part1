# ---------------------------------------------------------------------------
# LLM Response
# ---------------------------------------------------------------------------

async def generate_response(
    text: str,
    client: anthropic.AsyncAnthropic,
    task_mgr: Optional[ClaudeTaskManager],
    projects: List[str],
    conversation_history: List[Dict[str, str]],
    last_response: str = "",
    session_summary: str = "",
) -> str:
    """Generate JARVIS response using the unified JarvisBrain."""
    try:
        current_time = datetime.now().strftime("%I:%M %p")
        weather = "Weather data unavailable"
        
        # Build the system prompt
        system = JARVIS_SYSTEM_PROMPT.format(
            user_name=USER_NAME,
            current_time=current_time,
            weather_info=weather,
            project_dir=PROJECT_DIR,
            screen_context="Screen context limited on Windows",
            calendar_context="Calendar unavailable on Windows",
            mail_context="Mail unavailable on Windows",
            active_tasks=str(task_mgr.get_active_tasks()) if task_mgr else "[]",
            dispatch_context="",
            known_projects=", ".join(projects)
        )
        
        # Use the Unified Brain module
        return await brain.think(
            prompt=text,
            history=conversation_history,
            system_prompt=system
        )
        
    except Exception as e:
        log.error(f"Brain failure: {e}")
        traceback.print_exc()
        return "I'm having trouble reaching my internal brain components, sir."

# ---------------------------------------------------------------------------
# Background Summaries
# ---------------------------------------------------------------------------

async def generate_summary(prompt: str, system: str = "Summarize this in 1-2 sentences.") -> str:
    """Generate a short summary using the Brain."""
    try:
        return await brain.think(prompt=prompt, system_prompt=system)
    except Exception as e:
        log.error(f"Summary failed: {e}")
        return "Summary unavailable."

